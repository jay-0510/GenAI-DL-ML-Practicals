# Copy this file to .env and fill in real values -- .env itself is
# gitignored so real AWS settings never get committed.

AWS_REGION=us-east-1

# S3 bucket names are globally unique across ALL AWS accounts -- the
# value below is a placeholder and will almost certainly already be
# taken. Pick your own, e.g. include your account ID or initials.
S3_BUCKET_NAME=jay-patel-378311506052

# Titan Embeddings V2 -- see src/embeddings/titan_embeddings.py for why.
EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0

OPENSEARCH_COLLECTION_NAME=practical8-doc-ingestion
OPENSEARCH_INDEX_PREFIX=documents

TEXTRACT_POLL_INTERVAL_SECONDS=5
TEXTRACT_TIMEOUT_SECONDS=600

DEFAULT_CHUNK_OVERLAP=50
MAX_RETRY_ATTEMPTS=3
