# AWS region where Bedrock is enabled for your account
AWS_REGION=us-east-1

# Bedrock model identifier (must be enabled for your account/region)
BEDROCK_MODEL_ID="amazon.nova-micro-v1:0"

# AWS credentials — prefer `aws configure` / IAM roles over hardcoding these.
# Only set here for local dev if you're not using the AWS CLI credential chain.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

APP_ENV=development
LOG_LEVEL=INFO

# Comma-separated list of allowed classification categories
CLASSIFICATION_LABELS=finance,technology,sports,health,politics,entertainment,other
